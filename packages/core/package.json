{
  "name": "@curifin/core",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/curifin-core.cjs",
  "module": "./dist/curifin-core.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/curifin-core.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/curifin-core.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "pixi.js": "^8.9.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "rimraf": "^6.0.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.4",
    "vite-plugin-dts": "^4.5.4"
  }
}
