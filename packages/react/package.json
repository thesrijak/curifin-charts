{
  "name": "@curifin/react",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/curifin-react.cjs",
  "module": "./dist/curifin-react.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/curifin-react.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/curifin-react.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@curifin/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.4",
    "vite-plugin-dts": "^4.5.4"
  }
}
